# =============================================================================
# Supabase  (Project Settings → API)
# =============================================================================
# URL + publishable key are safe to commit (designed for the browser).
NEXT_PUBLIC_SUPABASE_URL=https://yifazhvphuzpdasmwllh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_cyMYK1nbaa8u_iE8BRl3dA_VXvRwkFc
# Server-only — used for trusted server-side jobs (sync, webhooks, etc.).
# Find it at Project Settings → API → service_role secret. NEVER commit it.
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Enable Banking  (https://enablebanking.com/)
# =============================================================================
# GoCardless Bank Account Data closed new free signups in mid-2025;
# Enable Banking is the replacement aggregator.
#
# app_id is the `kid` we use to sign API request JWTs — not a secret.
ENABLE_BANKING_APP_ID=1b3e1ef2-94fc-4b2c-b78e-96b555bdf68a
ENABLE_BANKING_ENV=sandbox

# Private key — keep this secret. Two ways to provide it (use either):
#   1. File path (great for local dev, default): point at the PEM in keys/.
#   2. Inline PEM string (great for Vercel etc.): paste full PEM with literal \n.
ENABLE_BANKING_PRIVATE_KEY_PATH=keys/enablebanking_private.pem
# ENABLE_BANKING_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Where the bank should redirect after consent. Must match a redirect_url
# registered with the Enable Banking application.
ENABLE_BANKING_REDIRECT_URI=http://localhost:3000/auth/banking/callback

# =============================================================================
# App
# =============================================================================
# Used as the redirect_uri base for the PSD2 consent callback.
NEXT_PUBLIC_APP_URL=http://localhost:3000
